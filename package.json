{
  "name": "keryx",
  "version": "0.1.0",
  "private": true,
  "description": "Keryx — a citation-toll reading agent. Pays creators every time their work is cited, in USDC on Arc.",
  "scripts": {
    "dev": "next dev -p 3939",
    "build": "next build",
    "start": "next start -p 3939",
    "lint": "eslint .",
    "generate-wallets": "node --import tsx --no-warnings scripts/generate-wallets.mts",
    "seed-sources": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/seed-sources.mts",
    "ask": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/ask.mts",
    "seed": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/seed-engine.mts",
    "metrics": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/metrics.mts",
    "preflight": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/preflight.mts",
    "arc:update": "node --import tsx --no-warnings scripts/arc-update.mts",
    "tunnel": "cloudflared tunnel --url http://localhost:3939",
    "ingest": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/ingest-source.mts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@circle-fin/x402-batching": "^2.0.4",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.47.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
