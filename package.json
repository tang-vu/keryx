{
  "name": "keryx",
  "version": "0.3.0",
  "private": true,
  "description": "Keryx — a citation-toll reading agent. Pays creators every time their work is cited, in USDC on Arc.",
  "scripts": {
    "dev": "next dev -p 3939",
    "build": "next build",
    "start": "next start -p 3939",
    "lint": "eslint .",
    "generate-wallets": "node --import tsx --no-warnings scripts/generate-wallets.mts",
    "seed-sources": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/seed-sources.mts",
    "ask": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/ask.mts",
    "seed": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/seed-engine.mts",
    "register-onchain": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/register-catalog-onchain.mts",
    "metrics": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/metrics.mts",
    "preflight": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/preflight.mts",
    "arc:update": "node --import tsx --no-warnings scripts/arc-update.mts",
    "a2a": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/a2a-client.mts",
    "mcp": "node --import tsx --no-warnings --env-file-if-exists=.env.local mcp/keryx-mcp-server.mts",
    "web": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/web-client.mts",
    "deploy": "bash scripts/deploy-vps.sh",
    "tunnel": "cloudflared tunnel --url http://localhost:3939",
    "withdraw": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/withdraw.mts",
    "ingest": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/ingest-source.mts",
    "migrate-ipfs": "node --import tsx --no-warnings --env-file-if-exists=.env.local scripts/migrate-content-to-ipfs.mts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@circle-fin/x402-batching": "^2.0.4",
    "@metamask/connect-evm": "^2.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@scalar/nextjs-api-reference": "^0.11.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "@tanstack/react-query": "^5.101.0",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "pinata": "^2.5.6",
    "radix-ui": "^1.4.3",
    "rate-limiter-flexible": "^11.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0",
    "siwe": "^3.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "topojson-client": "^3.1.0",
    "viem": "^2.47.1",
    "wagmi": "^3.6.17",
    "world-atlas": "^2.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-viem": "^2.1.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "hardhat": "^2.28.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
