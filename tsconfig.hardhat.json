{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "hardhat-dist"
  },
  "include": [
    "hardhat.config.ts",
    "contracts/**/*.ts",
    "scripts/deploy-source-registry.ts",
    "typechain-types/**/*.ts"
  ]
}
