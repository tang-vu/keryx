# ─── Keryx environment ───
# Copy to .env.local and fill in. .env.local is gitignored. Never commit real keys.

# ── LLM (the agent's reasoning brain) ──
# Anthropic preferred. If unset, Keryx runs in OFFLINE heuristic mode (dev only — not the demo path).
ANTHROPIC_API_KEY=
# Models (optional overrides)
KERYX_LLM_MODEL=claude-haiku-4-5-20251001
KERYX_SYNTHESIS_MODEL=claude-sonnet-4-6

# ── Database ──
# If SUPABASE vars are set → Supabase adapter (prod/deploy). Else → local SQLite at ./data/keryx.sqlite (dev).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Wallets (run `npm run generate-wallets`) ──
# SELLER = platform/treasury wallet. FUNDER = funds the agent's ephemeral spend wallet (fund this via faucet).
SELLER_ADDRESS=
SELLER_PRIVATE_KEY=
AGENT_FUNDER_ADDRESS=
AGENT_FUNDER_PRIVATE_KEY=

# ── Chain config (Arc testnet defaults; flip for mainnet) ──
KERYX_NETWORK=arcTestnet
KERYX_RPC_URL=https://rpc.testnet.arc.network
KERYX_USDC_ADDRESS=0x3600000000000000000000000000000000000000
KERYX_GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9

# ── Agent economics (USDC) ──
KERYX_DEFAULT_BUDGET=0.05          # default per-query budget
KERYX_CITATION_POOL_RATIO=0.5      # share of budget reserved for weighted citation rewards
KERYX_DEFAULT_FETCH_PRICE=0.002    # default per-source access toll for new sources

# ── App ──
BASE_URL=http://localhost:3000

# ── Traction (optional) ──
# arc-canteen auth is via `arc-canteen login` (GitHub OAuth), not env. circle CLI similar.
